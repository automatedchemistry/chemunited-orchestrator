                    <mxGeometry x="40" y="20" width="320" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="summary" value="Consumer flow: Mode -&gt; from_mode() -&gt; Data -&gt; inspect topology -&gt; update(patch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="70" width="1220" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="consumer" value="Consumer package&#xa;&#xa;- imports from subpackages&#xa;- builds Mode objects from config, UI, or protocol data&#xa;- compiles runtime Data objects&#xa;- reads topology for orchestration, visualization, or simulation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="260" width="240" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="components" value="chemunited_core.components&#xa;&#xa;Public model pairs&#xa;- ComponentMode / ComponentData&#xa;- FlowSource, Junction, PlugFlow&#xa;- PressureControl, BPR, Valve, Vessel&#xa;&#xa;Each Data object compiles ports, internal edges, and optional inventory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="360" y="140" width="320" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="connections" value="chemunited_core.connections&#xa;&#xa;- EdgeMode validates external connections&#xa;- EdgeData stores runtime geometry&#xa;- ConnectionType classifies hydraulic, heat, movement, or electronic links" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="340" y="410" width="320" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="common" value="chemunited_core.common&#xa;&#xa;- Element provides from_mode() and update()&#xa;- enums define shared categories and stable identifiers&#xa;- common metadata keeps Mode/Data behavior aligned" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;" parent="1" vertex="1">
