{
    // Python interpreter — points to the local .venv
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    "python.terminal.activateEnvInCurrentTerminal": true,

    // Linting / formatting (ruff + mypy match pyproject.toml)
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },

    // Ruff
    "ruff.path": ["${workspaceFolder}/.venv/Scripts/ruff.exe"],

    // Mypy
    "mypy-type-checker.importStrategy": "fromEnvironment",
    "mypy-type-checker.path": ["${workspaceFolder}/.venv/Scripts/mypy.exe"],
    "mypy-type-checker.args": [
        "--python-executable=${workspaceFolder}/.venv/Scripts/python.exe"
    ],

    // Test discovery
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": false,

    // Exclude heavy / generated directories from file watcher
    "files.watcherExclude": {
        "**/.venv/**": true,
        "**/build/**": true,
        "**/__pycache__/**": true
    },
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true
    },
    "search.exclude": {
        "**/.venv": true,
        "**/build": true
    }
}
